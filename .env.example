# =============================================================================
# MAC_ASD v12.0 — Environment Configuration
# =============================================================================
# Скопируйте этот файл в .env и заполните значения

# --- Profile ---
ASD_PROFILE=mac_studio

# --- LLM: Model overrides (опционально, оставить пустым для default) ---
# MODEL_PM=mlx-community/Llama-3.3-70B-Instruct-4bit
# MODEL_PTO=mlx-community/gemma-4-31b-it-4bit
# MODEL_SMETA=mlx-community/Qwen3.5-27B-4bit
# MODEL_LEGAL=mlx-community/Qwen3.5-27B-4bit
# MODEL_PROCUREMENT=mlx-community/Qwen3.5-27B-4bit
# MODEL_LOGISTICS=mlx-community/Qwen3.5-27B-4bit
# MODEL_ARCHIVE=mlx-community/gemma-4-e4b-it-4bit
# MODEL_EMBED=mlx-community/bge-m3-mlx-4bit
# MODEL_VISION=mlx-community/gemma-4-31b-it-4bit

# --- Paths ---
# BASE_DIR=/path/to/mac_asd
# WIKI_PATH=
# ARTIFACTS_PATH=

# --- PostgreSQL ---
POSTGRES_USER=oleg
POSTGRES_PASSWORD=asd_password
POSTGRES_DB=asd_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# --- Redis УДАЛЁН ---
# Redis заменён на in-process кэширование (cachetools)
# Для single-user Mac Studio Redis избыточен, экономия 2GB RAM

# --- Performance ---
RAM_BUDGET_GB=120

# --- id-prosto.ru Integration ---
# Авторизация для доступа к закрытым шаблонам ИД
# Способ 1: логин/пароль + 2Captcha (автоматическая авторизация)
# ID_PROSTO_LOGIN=your_email@example.com
# ID_PROSTO_PASSWORD=your_password
# TWOCAPTCHA_API_KEY=your_2captcha_api_key

# Способ 2: передача cookies (самый быстрый — без капчи)
# Получите cookies из DevTools браузера после ручного входа
# ID_PROSTO_COOKIES={"session_id":"abc123","_ga":"GA1.2..."}

# --- Google Workspace ---
# Путь к JSON-ключу Service Account
# GOOGLE_APPLICATION_CREDENTIALS=credentials/google_service_account.json

# Google Drive — ID папок
# GOOGLE_DRIVE_PROJECTS_FOLDER=
# GOOGLE_DRIVE_TEMPLATES_FOLDER=
# GOOGLE_DRIVE_CONTRACTS_FOLDER=
# GOOGLE_DRIVE_ID_FOLDER=
# GOOGLE_DRIVE_VOR_FOLDER=
# GOOGLE_DRIVE_ESTIMATES_FOLDER=

# Google Docs — ID шаблонов документов
# GOOGLE_DOCS_AOSR_TEMPLATE=
# GOOGLE_DOCS_AOOK_TEMPLATE=
# GOOGLE_DOCS_PROTOCOL_TEMPLATE=
# GOOGLE_DOCS_LETTER_TEMPLATE=
# GOOGLE_DOCS_CLAIM_TEMPLATE=

# Google Sheets — ID таблиц-шаблонов
# GOOGLE_SHEETS_VOR_TEMPLATE=
# GOOGLE_SHEETS_ESTIMATE_TEMPLATE=
# GOOGLE_SHEETS_JOURNAL_TEMPLATE=

# Gmail
# GOOGLE_GMAIL_SENDER=

# --- Лабораторный контроль ---
# Google Drive — папки для лабораторных документов
# GOOGLE_DRIVE_LAB_FOLDER=         # Папка: Лаборатория
# GOOGLE_DRIVE_LAB_REPORTS_FOLDER= # Папка: Заключения

# Google Docs — шаблоны лабораторных документов
# GOOGLE_DOCS_LAB_REQUEST_TEMPLATE=  # Письмо-обращение в лабораторию
# GOOGLE_DOCS_LAB_CONTRACT_TEMPLATE= # Договор на оказание услуг лаборатории
# GOOGLE_DOCS_LAB_ACT_TEMPLATE=      # Акт выполненных работ

# Google Sheets — журналы и реестры лаб. контроля
# GOOGLE_SHEETS_LAB_SAMPLE_JOURNAL=     # Журнал образцов бетона
# GOOGLE_SHEETS_LAB_CONTROL_REGISTER=   # Реестр лабораторного контроля
