# =============================================================================
# ASD v11.0 — Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# cp .env.example .env
#
# PROFILES:
#   dev_linux   — Linux + Ollama + RTX (разработка и тестирование)
#   mac_studio  — Mac Studio M4 Max 128GB + MLX (продакшен)
# =============================================================================

# --- Profile ---
ASD_PROFILE=dev_linux

# --- Project Paths (absolute or relative to project root) ---
# Leave empty to auto-detect from project location
BASE_DIR=
WIKI_PATH=
ARTIFACTS_PATH=

# --- LLM: Ollama (used in both profiles for embeddings) ---
OLLAMA_BASE_URL=http://localhost:11434

# --- LLM: Model overrides (optional, overrides profile defaults) ---
# MODEL_PM=qwen3:32b
# MODEL_LEGAL=qwen3:32b
# MODEL_PTO=qwen3:32b
# MODEL_SMETA=qwen3:32b
# MODEL_PROCUREMENT=qwen3:32b
# MODEL_LOGISTICS=qwen3:32b
# MODEL_ARCHIVE=qwen3:8b
# MODEL_EMBED=bge-m3
# MODEL_VISION=minicpm-v

# --- PostgreSQL ---
POSTGRES_USER=oleg
POSTGRES_PASSWORD=asd_password
POSTGRES_DB=asd_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- RAM Budget (GB) ---
# dev_linux: 28 (32GB DDR5 - system reserve)
# mac_studio: 120 (128GB Unified Memory - system reserve)
RAM_BUDGET_GB=28
