# =============================================================================
# MAC_ASD v12.0 — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Profile (REQUIRED) ---
# Choose: dev_linux (Ollama) or mac_studio (MLX + Ollama)
ASD_PROFILE=dev_linux

# --- Project Paths ---
# Project root (auto-detected by default — change only if needed)
# BASE_DIR=/path/to/MAC_ASD
# WIKI_PATH=/path/to/obsidian/wiki
# ARTIFACTS_PATH=/path/to/artifacts

# --- LLM: Ollama ---
OLLAMA_BASE_URL=http://127.0.0.1:11434

# --- LLM: Model Overrides (optional) ---
# Uncomment to override specific models for agents:
# MODEL_PM=gemma4:31b-cloud
# MODEL_PTO=gemma4:31b-cloud
# MODEL_SMETA=gemma4:31b-cloud
# MODEL_LEGAL=gemma4:31b-cloud
# MODEL_PROCUREMENT=gemma4:31b-cloud
# MODEL_LOGISTICS=gemma4:31b-cloud
# MODEL_ARCHIVE=gemma4:31b-cloud
# MODEL_EMBED=bge-m3
# MODEL_VISION=minicpm-v

# --- PostgreSQL Database ---
POSTGRES_USER=oleg
POSTGRES_PASSWORD=asd_password
POSTGRES_DB=asd_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# --- Performance ---
# RAM budget in GB (for Mac Studio monitoring)
RAM_BUDGET_GB=78

# --- id-prosto.ru Integration (optional) ---
# ID_PROSTO_LOGIN=
# ID_PROSTO_PASSWORD=
# ID_PROSTO_COOKIES={}
# TWOCAPTCHA_API_KEY=

# --- Yandex Geocoder (бесплатный ключ) ---
# Получить: https://developer.tech.yandex.ru/ (кнопка «Получить ключ»)
# Лимит: 1000 запросов/день
YANDEX_GEOCODER_KEY=

# --- Telegram Ingestion (optional) ---
# API_ID=
# API_HASH=
# PHONE_NUMBER=
